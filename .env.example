# PulseRetain — environment variables
#
# The React FRONTEND needs no .env to run: the Cognito config lives in
# src/aws-config.js and the Lambda URL is set in src/App.js (both are public,
# non-secret values that ship in the browser bundle).
#
# The variables below are SERVER-SIDE ONLY — set them in the AWS Lambda
# function's environment (Configuration -> Environment variables). Never commit
# real values to this repo. Listed here for reference / self-hosting.

ANTHROPIC_API_KEY=        # Anthropic API key (Claude Haiku 4.5)
TWILIO_ACCOUNT_SID=       # Twilio Account SID
TWILIO_AUTH_TOKEN=        # Twilio Auth Token
TWILIO_PHONE_NUMBER=      # Twilio sending number, e.g. +1XXXXXXXXXX
NOTIFY_EMAIL=             # SES-verified address for demo-request notifications
